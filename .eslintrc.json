{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_|next" }],
    "no-console": "off",
    "no-undef": "error",
    "prefer-const": "warn",
    "eqeqeq": ["error", "always"],
    "no-var": "error",
    "curly": ["error", "all"],
    "no-duplicate-imports": "error",
    "no-return-await": "warn"
  },
  "ignorePatterns": ["node_modules/", "dist/", "coverage/"]
}
