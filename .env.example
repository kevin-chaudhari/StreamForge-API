# ─────────────────────────────────────────────────────────────────────────────
# Watchly API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# The port the Express server will listen on.
PORT=3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Full MongoDB connection string (Atlas or self-hosted).
# Example: mongodb+srv://<user>:<password>@cluster0.mongodb.net
MONGO_URI=your-mongodb-uri

# ── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origin(s) for cross-origin requests.
# Use a specific URL in production (e.g., https://yourfrontend.com).
# Use * only during local development.
CORS_ORIGIN=*

# ── JWT — Access Token ────────────────────────────────────────────────────────
# Secret key used to sign access tokens. Use a long, random string.
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key

# Access token lifespan. Supports ms, s, m, h, d notation (e.g., 15m, 1d).
ACCESS_TOKEN_EXPIRY=1d

# ── JWT — Refresh Token ───────────────────────────────────────────────────────
# Secret key used to sign refresh tokens. Must be different from ACCESS_TOKEN_SECRET.
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key

# Refresh token lifespan. Longer than access token.
REFRESH_TOKEN_EXPIRY=10d

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Media storage for videos, thumbnails, and avatars.
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for AI-powered video description generation (GPT-4o-mini).
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ── Node Environment ──────────────────────────────────────────────────────────
# Set to "production" in deployed environments for security hardening.
# In development, error stack traces are included in API error responses.
NODE_ENV=development
